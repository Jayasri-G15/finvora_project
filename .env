# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret

# Transaction Pooler (runtime, port 6543) — from Settings → Database → Connection Pooling
DATABASE_URL=postgresql+asyncpg://postgres.your-ref:your-password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?prepared_statement_cache_size=0

# Direct Connection (migrations only, port 5432) — from Settings → Database
ALEMBIC_DATABASE_URL=postgresql+psycopg2://postgres:your-password@db.your-ref.supabase.co:5432/postgres

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# ─── n8n Webhook ─────────────────────────────────────────────────────────────
N8N_WEBHOOK_SECRET=5fde8af48033611bd32e5e7edd53779622620970882a738e

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
UPLOAD_DIR=/app/uploads
MAX_ATTACHMENT_SIZE_MB=25
