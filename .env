# ─── Application ────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=d63727023c47c00995d19dd99df717253f13e7d6dfb2548e48d48af6d893d4fd
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://finvora:finvora_pass@postgres:5432/finvora_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── Google OAuth + Gmail API ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
GOOGLE_PUBSUB_TOPIC=projects/your-gcp-project/topics/finvora-gmail-watch

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=d63727023c47c00995d19dd99df717253f13e7d6dfb2548e48d48af6d893d4fd
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-openai-key-here...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# ─── File Storage ────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_ATTACHMENT_SIZE_MB=25

# ─── SMTP (optional — alert email dispatch) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@finvora.ai
SMTP_PASSWORD=your-smtp-app-password

# ─── Encryption (Fernet key for token fields) ────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=ThUdE3B9tkrcYHPCmXHwK5aPcysloO6JMg7RcSCuolQ=
