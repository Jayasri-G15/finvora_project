APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-32-char-string
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

DATABASE_URL=postgresql+asyncpg://finvora:finvora_pass@postgres:5432/finvora_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
GOOGLE_PUBSUB_TOPIC=projects/your-gcp-project/topics/finvora-gmail-watch

JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

UPLOAD_DIR=/app/uploads
MAX_ATTACHMENT_SIZE_MB=25

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@finvora.ai
SMTP_PASSWORD=your-smtp-app-password

ENCRYPTION_KEY=your-fernet-base64-key
