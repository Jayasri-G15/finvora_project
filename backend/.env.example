# ── Supabase ─────────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret

# Transaction Pooler (runtime) — Settings → Database → Connection Pooling (port 6543)
DATABASE_URL=postgresql+asyncpg://postgres.your-ref:your-password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?prepared_statement_cache_size=0

# Direct Connection (Alembic migrations only) — Settings → Database (port 5432)
ALEMBIC_DATABASE_URL=postgresql+psycopg2://postgres:your-password@db.your-ref.supabase.co:5432/postgres

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# ── n8n Integration ──────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(24))"
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret

# n8n webhook URL for triggering historical Gmail sync (optional)
N8N_TRIGGER_WEBHOOK=

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
UPLOAD_DIR=uploads
MAX_ATTACHMENT_SIZE_MB=25
