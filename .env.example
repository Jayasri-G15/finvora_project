# ════════════════════════════════════════════════════════════════════════════
# Finvora AI — Environment Variables Reference
# ════════════════════════════════════════════════════════════════════════════
#
# This file is for reference only. Real credentials go in the service folders:
#
#   Backend  →  backend/.env          (copy from backend/.env.example)
#   Frontend →  frontend/.env.local   (copy from frontend/.env.local.example)
#
# DO NOT add real credentials here. This file IS committed to git.
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# BACKEND  (backend/.env)
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — get from: dashboard.supabase.com → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret           # Settings → API → JWT Settings

# Database — Supabase PostgreSQL
# Transaction Pooler (runtime)  → Settings → Database → Connection Pooling, port 6543
DATABASE_URL=postgresql+asyncpg://postgres.your-ref:your-password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?prepared_statement_cache_size=0
# Direct Connection (Alembic only) → Settings → Database → Direct connection, port 5432
ALEMBIC_DATABASE_URL=postgresql+psycopg2://postgres:your-password@db.your-ref.supabase.co:5432/postgres

# OpenAI (GPT-4o for financial extraction + AI CFO insights)
OPENAI_API_KEY=sk-proj-your-openai-key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# n8n → FastAPI webhook security
# Generate: python -c "import secrets; print(secrets.token_hex(24))"
# Set the SAME value in n8n environment as FINVORA_WEBHOOK_SECRET
N8N_WEBHOOK_SECRET=generate-a-random-secret-here

# n8n historical sync trigger webhook URL
# Leave empty until you create the trigger webhook in n8n (see n8n/README.md)
N8N_TRIGGER_WEBHOOK=

# Application
APP_ENV=development
APP_DEBUG=true
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
UPLOAD_DIR=uploads
MAX_ATTACHMENT_SIZE_MB=25

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND  (frontend/.env.local)
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─────────────────────────────────────────────────────────────────────────────
# n8n ENVIRONMENT VARIABLES  (set inside n8n Cloud → Settings → Variables)
# ─────────────────────────────────────────────────────────────────────────────

# FINVORA_BACKEND_URL = https://your-api.up.railway.app   (Railway backend URL)
# FINVORA_WEBHOOK_SECRET = <same value as N8N_WEBHOOK_SECRET above>
# FINVORA_USER_EMAIL = your-gmail@gmail.com               (Gmail connected to n8n)

# ─────────────────────────────────────────────────────────────────────────────
# REMOVED — no longer part of this architecture
# ─────────────────────────────────────────────────────────────────────────────
#   ✗ ANTHROPIC_API_KEY / CLAUDE_MODEL  → replaced by OpenAI GPT-4o
#   ✗ REDIS_URL / CELERY_BROKER_URL     → replaced by n8n
#   ✗ GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET → handled by Supabase Auth
#   ✗ GOOGLE_REDIRECT_URI / GOOGLE_PUBSUB_TOPIC → replaced by n8n Gmail Trigger
#   ✗ JWT_SECRET_KEY / ENCRYPTION_KEY / APP_SECRET_KEY → replaced by SUPABASE_JWT_SECRET
#   ✗ SMTP_HOST / SMTP_PORT / SMTP_USER → not used
# ─────────────────────────────────────────────────────────────────────────────
